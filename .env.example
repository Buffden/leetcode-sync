# Copy this file to .env and fill in your real values.
# Never commit .env — it is already in .gitignore.

# GitHub personal access token (needs repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The repo where solutions will be committed — format: owner/repo
GITHUB_REPO=Buffden/leetcode-companywise-interview-questions

# From browser devtools → Application → Cookies on leetcode.com
LEETCODE_CSRF_TOKEN=your_csrf_token_here
LEETCODE_SESSION=your_session_cookie_here

# Optional overrides
# FILTER_DUPLICATE_SECS=86400
# DESTINATION_FOLDER=
# VERBOSE=true
# COMMIT_HEADER=[LeetCode]
